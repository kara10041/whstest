import streamlit as st
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# 데이터 로드 함수
def load_dataset():
    data = pd.read_csv('Traffic.csv')
    table = pd.DataFrame({'Counts': [data.shape[0], data.shape[1]]}, index=['Rows', 'Columns'])
    return data, table

# 시각화 함수
def plot_weekday_hourly_mood_score(data):
    """
    요일별 및 시간대별 평균 기분스코어를 시각화하는 함수.
    Streamlit 환경에서 작동하도록 설정.
    """

    # 24시간 숫자를 12시간제 AM/PM 표기로 변환
    def hour_label(hour):
        period = 'AM' if hour < 12 else 'PM'
        hour12 = hour % 12
        if hour12 == 0:
            hour12 = 12
        return f'{hour12}{period}'
    
    # 시간대 라벨 생성
    data['TimeSlot'] = data['Hour'].apply(hour_label)

    
    # 요일별 평균 통행량 계산
    weekday_avg = data.groupby('weekday')['mood_score'].mean().reindex(
        ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']
    )

    # 시간대별 평균 통행량 계산
    hour_avg = data.groupby('TimeSlot')['mood_score'].mean()

    # 요일별 평균 통행량 그래프
    st.subheader('Average Mood Score by Day of the Week')
    fig, ax = plt.subplots(figsize=(12, 5))
    ax.bar(weekday_avg.index, weekday_avg.values)
    ax.set_title('Average Mood Score by Day of the Week')
    ax.set_xlabel('Day of the Week')
    ax.set_ylabel('Average Mood Score')
    ax.grid(axis='y', linestyle='--', alpha=0.7)
    st.pyplot(fig)

    # 시간대별 평균 통행량 그래프
    st.subheader('Average Mood Score by Hour of the Day')
    fig, ax = plt.subplots(figsize=(12, 5))
    ax.plot(hour_avg.index, hour_avg.values, marker='o')
    ax.set_title('Average Mood Score by Hour of the Day')
    ax.set_xlabel('Hour of the Day')
    ax.set_ylabel('Average Mood Score')
    ax.set_xticks(range(0, 24))
    ax.grid(axis='both', linestyle='--', alpha=0.7)
    return fig


