    def filter_weather_data(data, start_date, end_date, temp_range, humidity_range, precip_range):
        """
        날짜, 기온, 습도, 강수량 조건에 따라 데이터를 중첩 필터링합니다.
        """
    
        # 날짜 컬럼 변환
        data['date_iso'] = pd.to_datetime(data['date_iso'])
    
        # 입력 날짜 변환
        start_date = pd.to_datetime(start_date)
        end_date = pd.to_datetime(end_date)
    
        # 날짜 필터링
        filtered_data = data[
            (data['date_iso'] >= start_date) &
            (data['date_iso'] <= end_date)
        ]
    
        # 기온 필터링
        filtered_data = filtered_data[
            (filtered_data['temperature_c'] >= temp_range[0]) &
            (filtered_data['temperature_c'] <= temp_range[1])
        ]
    
        # 습도 필터링
        filtered_data = filtered_data[
            (filtered_data['humidity_percent'] >= humidity_range[0]) &
            (filtered_data['humidity_percent'] <= humidity_range[1])
        ]
    
        # 강수량 필터링
        filtered_data = filtered_data[
            (filtered_data['precipitation_mm'] >= precip_range[0]) &
            (filtered_data['precipitation_mm'] <= precip_range[1])
        ]
    
        return filtered_data
    
    def plot_filtered_weather_mood(data):
        """
        필터링된 데이터에서 weather별 평균 mood_score를 막대 그래프로 시각화합니다.
        """
    
        weather_avg = data.groupby('weather')['mood_score'].mean()
    
        fig, ax = plt.subplots(figsize=(10, 6))
        ax.bar(weather_avg.index, weather_avg.values)
        ax.set_title('Average Mood Score by Weather')
        ax.set_xlabel('Weather')
        ax.set_ylabel('Average Mood Score')
        ax.grid(axis='y', linestyle='--', alpha=0.7)
        plt.tight_layout()
        return fig


