def plot_daily_mood_trend_with_filter(data, start_date, end_date):
    """
    날짜(Date) 범위를 필터링하여 추세를 라인 차트로 시각화합니다.
    
    Parameters:
        data (pd.DataFrame): 교통 데이터를 포함하는 DataFrame.
        start_date (str): 필터링 시작 날짜.
        end_date (str): 필터링 종료 날짜.
    """
    # 날짜 필터링
    filtered_data = data[(data['Date'] >= start_date) & (data['Date'] <= end_date)]
    daily_totals = filtered_data.groupby('Date')['Total'].sum()

    # 라인 차트 생성
    fig, ax = plt.subplots(figsize=(12, 6))
    ax.plot(daily_totals.index, daily_totals.values, marker='o')
    ax.set_title('Daily Traffic Volume Trend')
    ax.set_xlabel('Date')
    ax.set_ylabel('Total Traffic Volume')
    ax.grid(axis='both', linestyle='--', alpha=0.7)
    plt.tight_layout()
    return fig


def plot_time_filtered_heatmap(data, hour_range):
    """
    시간대(Hour) 범위를 필터링하여 요일 및 시간대별 교통량을 열지도로 시각화합니다.
    
    Parameters:
        data (pd.DataFrame): 교통 데이터를 포함하는 DataFrame.
        hour_range (tuple): 필터링할 시간대 범위 (start_hour, end_hour).
    """
    # 시간 정보 변환
    data['Hour'] = pd.to_datetime(data['Time'], format='%I:%M:%S %p').dt.hour
    
    # 시간대 필터링
    start_hour, end_hour = hour_range
    filtered_data = data[(data['Hour'] >= start_hour) & (data['Hour'] <= end_hour)]
    
    # 피벗 테이블 생성
    heatmap_data = filtered_data.pivot_table(
        index='Day of the week', columns='Hour', values='Total', aggfunc='mean'
    ).reindex(['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'])

    # 열지도 생성
    fig, ax = plt.subplots(figsize=(12, 8))
    sns.heatmap(heatmap_data, ax=ax, cmap='YlGnBu', annot=True, fmt=".1f", cbar_kws={'label': 'Average Traffic Volume'})
    ax.set_title(f'Average Traffic Volume (Hours: {start_hour}-{end_hour})')
    ax.set_xlabel('Hour of the Day')
    ax.set_ylabel('Day of the Week')
    plt.tight_layout()
    return fig


