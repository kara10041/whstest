    st.sidebar.table(table)

    # 데이터 전처리
    data['Hour'] = pd.to_datetime(data['Time'], format='%I:%M:%S %p').dt.hour
    
    # 교통 상황 필터
    situations = st.sidebar.multiselect(
        "Select Traffic Situations",
        options=data['Traffic Situation'].unique(),
        default=data['Traffic Situation'].unique()
    )

    # 날짜 필터
    min_date, max_date = data['Date'].min(), data['Date'].max()
    start_date, end_date = st.sidebar.slider(
        "Select Date Range",
        min_value=min_date,
        max_value=max_date,
        value=(min_date, max_date)
    )
    
    # 시간대 필터
    hour_range = st.sidebar.slider(
        "Select Hour Range",
        min_value=0,
        max_value=23,
        value=(0, 23)
    )
    
    # 탭으로 그래프 선택
    st.write("### Explore Traffic Data")
    tab1, tab2, tab3, tab4, tab5 = st.tabs(
        ["Weekday & Hourly", "Traffic Situation", "Vehicle Totals", "Daily Trend", "Heatmap"]
    )
    
    with tab1:
        st.write("#### Weekday & Hourly Traffic Volume")
        week_hourly_traffic_fig = plot_weekday_hourly_traffic(data)
        st.pyplot(week_hourly_traffic_fig)
    
    with tab2:
        st.write("#### Traffic Situation Distribution")
        filtered_situation_fig = plot_filtered_traffic_situation(data, situations)
        st.pyplot(filtered_situation_fig)
    
    with tab3:
        st.write("#### Total Traffic Counts by Vehicle Type")
        vehicle_totals_fig = plot_vehicle_type_totals(data)
        st.pyplot(vehicle_totals_fig)
    
    with tab4:
        st.write("#### Daily Traffic Volume Trend")
        daily_trend_fig = plot_daily_traffic_trend_with_filter(data, start_date, end_date)
        st.pyplot(daily_trend_fig)
    
    with tab5:
        st.write("#### Weekday and Hourly Heatmap")
        time_filtered_heatmap_fig = plot_time_filtered_heatmap(data, hour_range)
        st.pyplot(time_filtered_heatmap_fig)

# 앱 실행
if __name__ == "__main__":
